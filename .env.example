PROXY_API_KEY=

# Netlify AI Gateway injects provider keys/base URLs automatically on Netlify.
# Set these locally only if you want to test without Netlify AI Gateway.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional. Use these only if you want to point the proxy at a compatible upstream.
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
